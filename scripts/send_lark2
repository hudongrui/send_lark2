# Load Config
def load_config(config_file: Path):
    try:
        # Load config file
        config = ConfigParser()
        config.read(config_file)

        # Set environment variables
        os.environ['LARK_QUERY_TIMEOUT'] = config.get('default', 'QUERY_TIMEOUT')
        os.environ['LARK_PAYLOAD_SIZE'] = config.get('default', 'PAYLOAD_SIZE')
        os.environ['LARK_APP_ID'] = config.get('default', 'APP_ID')
        os.environ['LARK_APP_SECRET'] = config.get('default', 'APP_SECRET')

        os.environ['LARK_CLIENT_HOST'] = config.get('cli', 'CLIENT_HOST')
        os.environ['LARK_CLIENT_PORT'] = config.get('cli', 'CLIENT_PORT')

        return config
    except Exception as e:
        click.echo(f"Error loading config file: {str(e)}", err=True)
        raise


